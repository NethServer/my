# sync Tool Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED CONFIGURATION
# ===========================================
# Logto tenant configuration
LOGTO_TENANT_ID=your-tenant-id

# Logto Management API (M2M app credentials)
LOGTO_BACKEND_APP_ID=your-backend-m2m-app-id
LOGTO_BACKEND_APP_SECRET=your-backend-m2m-app-secret

# Required for 'sync init' command only
LOGTO_TENANT_DOMAIN=your-domain.com
APP_URL=https://your-app-domain.com

# ===========================================
# OPTIONAL CONFIGURATION
# ===========================================
# Uncomment and modify these variables if you need to override defaults

# Backend API configuration (for sync init)
#API_BASE_URL=http://localhost:8080

# Logging configuration
#LOG_LEVEL=info

# ===========================================
# AUTO-DERIVED URLS (DO NOT SET MANUALLY)
# ===========================================
# The following URLs are automatically derived from LOGTO_TENANT_ID:
# LOGTO_BASE_URL=https://{LOGTO_TENANT_ID}.logto.app

# Database connection for reverse sync
DATABASE_URL=postgresql://noc_user:noc_password@localhost:5432/noc?sslmode=disable