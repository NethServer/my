{{ define "telegram.message" -}}
{{ if .Alerts.Firing -}}
{{ if eq (len .Alerts.Firing) 1 }}🔴 <b>ALERT FIRING</b>{{ else }}🚨 <b>{{ len .Alerts.Firing }} ALERTS FIRING</b>{{ end }}

{{ range .Alerts.Firing -}}
<b>{{ .Labels.alertname }}</b>
{{ if eq .Labels.severity "critical" }}🔴 <i>Critical</i>{{ else if eq .Labels.severity "warning" }}🟠 <i>Warning</i>{{ else }}🔵 <i>Info</i>{{ end }}{{ if .Labels.system_name }} | 🖥️ <code>{{ .Labels.system_name }}</code>{{ end }}
{{ if .Annotations.summary_en }}{{ .Annotations.summary_en }}{{ else if .Annotations.summary }}{{ .Annotations.summary }}{{ end }}
{{ end -}}
{{ end -}}
{{ if .Alerts.Resolved -}}
✅ <b>{{ len .Alerts.Resolved }} alert{{ if gt (len .Alerts.Resolved) 1 }}s{{ end }} RESOLVED</b>

{{ range .Alerts.Resolved -}}
<b>{{ .Labels.alertname }}</b>
{{ if eq .Labels.severity "critical" }}🟢 <i>Critical</i>{{ else if eq .Labels.severity "warning" }}🟡 <i>Warning</i>{{ else }}🔵 <i>Info</i>{{ end }}{{ if .Labels.system_name }} | 🖥️ <code>{{ .Labels.system_name }}</code>{{ end }}
{{ if .Annotations.summary_en }}{{ .Annotations.summary_en }}{{ else if .Annotations.summary }}{{ .Annotations.summary }}{{ end }}
{{ end -}}
{{ end -}}
{{- end }}
