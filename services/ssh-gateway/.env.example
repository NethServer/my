# SSH server
SSH_LISTEN_ADDRESS=0.0.0.0:2222          # SSH server bind address
SSH_HOST_KEY_PATH=./ssh_host_key          # Path to SSH host key (auto-generated if missing)

# Database (for SSH access logs)
DATABASE_URL=postgresql://noc_user:noc_password@localhost:5432/noc?sslmode=disable

# HTTP health check
HTTP_LISTEN_ADDRESS=127.0.0.1:8083       # Health check endpoint bind address

# Backend API
BACKEND_URL=http://localhost:8080         # Backend service URL for session cleanup

# Support service
SUPPORT_SERVICE_URL=http://localhost:8082 # Support service URL for tunnel bridging
# IMPORTANT: Must match the INTERNAL_SECRET in the support service
SUPPORT_INTERNAL_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# Redis
REDIS_URL=redis://localhost:6379          # Redis connection URL
REDIS_DB=0                                # Redis database number (shared with backend for auth keys)

# Auth flow
AUTH_NONCE_TTL=5m                          # How long a nonce is valid for browser auth
AUTH_POLL_INTERVAL=500ms                   # How often to check Redis for auth result
AUTH_POLL_TIMEOUT=5m                       # Maximum time to wait for browser auth
APP_URL=https://my.localtest.me            # Base URL of the app (same as backend APP_URL, used to build SSH auth callback URL)
KEY_AUTH_TTL=4h                            # How long a cached SSH public key remains valid (skip browser auth on reconnect)

# Logging
LOG_LEVEL=debug                           # Log level: debug, info, warn, error
LOG_FORMAT=console                        # Log format: console (human-readable) or json
