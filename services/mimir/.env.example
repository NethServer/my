# Mimir / Alerting Stack - environment variables
# Copy to mimir/.env and fill in actual values

# S3-compatible storage credentials (DigitalOcean Spaces or AWS S3)
S3_ENDPOINT=ams3.digitaloceanspaces.com
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
MIMIR_S3_ALERTMANAGER_BUCKET=your-mimir-alertmanager-bucket
