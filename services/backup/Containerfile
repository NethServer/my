# Garage bundled with the baseline single-node config used in development.
# The production backup target is DigitalOcean Spaces, so this image is not
# deployed by the current Render blueprint; it exists for parity with the
# other services/ directories and for ad-hoc self-hosted deployments.
FROM docker.io/dxflrs/garage:v1.0.1

# Bake the default config. Operators can override it at runtime by
# mounting a different file at /etc/garage/garage.toml.
COPY garage-local.toml /etc/garage/garage.toml

# S3 API + admin API ports. RPC (3901) stays container-internal.
EXPOSE 3900 3903

ENTRYPOINT ["/garage", "-c", "/etc/garage/garage.toml", "server"]
