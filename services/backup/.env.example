# Backup local development — override knobs for the Garage compose.
# Copy to services/backup/.env if you need to change the defaults.

# Compose project prefix — controls container, network, and volume names
# (<prefix>-garage, <prefix>-network, <prefix>-data, <prefix>-meta).
# Change if you run the stack alongside another backup-local instance.
#COMPOSE_PROJECT_NAME=backup-local
