# Backup local development — Garage secrets.
# Copy to services/backup/.env and fill in the two secrets below.

# 32-byte hex (64 chars) shared by every Garage node for cluster RPC.
# Generate with: openssl rand -hex 32
GARAGE_RPC_SECRET=

# Bearer token for Garage's admin API. Do NOT reuse the RPC secret.
# Generate with: openssl rand -hex 32
GARAGE_ADMIN_TOKEN=

# Compose project prefix — controls container, network, and volume names.
# Change if you run the stack alongside another backup-local instance.
#COMPOSE_PROJECT_NAME=backup-local
