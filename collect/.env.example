# Collect Configuration File
# Copy this file to .env and modify the values as needed

# ===========================================
# REQUIRED CONFIGURATION
# ===========================================
# PostgreSQL connection string (shared 'noc' database)
DATABASE_URL=postgresql://noc_user:noc_password@localhost:5432/noc?sslmode=disable

# Redis connection URL
REDIS_URL=redis://localhost:6379

# ===========================================
# OPTIONAL CONFIGURATION
# ===========================================
# Uncomment and modify these variables if you need to override defaults

# Server configuration
#LISTEN_ADDRESS=127.0.0.1:8081

# Database connection pool settings
#DATABASE_MAX_CONNS=25
#DATABASE_MAX_IDLE=5
#DATABASE_CONN_MAX_AGE=1h

# Redis configuration
#REDIS_DB=1
#REDIS_PASSWORD=

# Redis connection settings
#REDIS_MAX_RETRIES=3
#REDIS_DIAL_TIMEOUT=5s
#REDIS_READ_TIMEOUT=3s
#REDIS_WRITE_TIMEOUT=3s

# Queue configuration
#QUEUE_INVENTORY_NAME=collect:inventory
#QUEUE_PROCESSING_NAME=collect:processing
#QUEUE_NOTIFICATION_NAME=collect:notifications

# Queue processing settings
#QUEUE_BATCH_SIZE=10
#QUEUE_RETRY_ATTEMPTS=3

# Worker configuration
#WORKER_INVENTORY_COUNT=5
#WORKER_PROCESSING_COUNT=3
#WORKER_NOTIFICATION_COUNT=2

# Worker management
#WORKER_SHUTDOWN_TIMEOUT=30s
#WORKER_HEARTBEAT_INTERVAL=30s

# Inventory processing
#INVENTORY_MAX_AGE=2160h
#INVENTORY_CLEANUP_INTERVAL=6h

# Processing settings
#INVENTORY_DIFF_DEPTH=10

# System authentication
#SYSTEM_SECRET_MIN_LENGTH=32

# Authentication cache
#SYSTEM_AUTH_CACHE_TTL=24h

# API configuration
#API_MAX_REQUEST_SIZE=10485760  # 10MB
#API_REQUEST_TIMEOUT=30s

# Health check configuration
#HEALTH_CHECK_INTERVAL=30s

# Notification configuration
#NOTIFICATION_RETRY_ATTEMPTS=3

# Heartbeat monitoring configuration
#HEARTBEAT_TIMEOUT_MINUTES=10

# Backup storage (DigitalOcean Spaces — shared S3 account with Mimir)
# Endpoint, access key, and secret key are the same values configured for
# Mimir (MIMIR_S3_*). Only the bucket differs — a dedicated bucket for
# appliance configuration backups.
#S3_ENDPOINT=https://ams3.digitaloceanspaces.com
# Region value used in SigV4 signing. For DO Spaces use the region code
# (ams3, nyc3, fra1, …). For AWS S3 use the target region (eu-west-1, …).
# For most emulators (MinIO, Garage) any non-empty value works; the code
# falls back to "us-east-1" when unset.
#BACKUP_S3_REGION=ams3
#BACKUP_S3_BUCKET=my-backups-dev
#S3_ACCESS_KEY=
#S3_SECRET_KEY=
# Set to "true" only against local S3 emulators that require path-style
# addressing (e.g. MinIO or Garage for development). Spaces uses virtual-
# hosted style (default false).
#BACKUP_S3_USE_PATH_STYLE=false

# Backup ingest limits
#BACKUP_MAX_UPLOAD_SIZE=2147483648      # 2 GB per upload
#BACKUP_MAX_PER_SYSTEM=10               # number of backups retained per system
#BACKUP_MAX_SIZE_PER_SYSTEM=524288000   # 500 MB total per system
#BACKUP_MAX_SIZE_PER_ORG=107374182400   # 100 GB aggregate per organization; set to 0 to disable (logged at startup)

# Per-system ingest rate limits (Redis-backed, fail-open on Redis outage).
# Appliances upload on a daily timer, so these numbers are generous —
# their job is to block flood-style abuse. Set either to 0 to disable.
#BACKUP_RATE_LIMIT_PER_MINUTE=6
#BACKUP_RATE_LIMIT_PER_HOUR=60

# Batch processing configuration
#BATCH_PROCESSOR_SIZE=100
#BATCH_PROCESSOR_TIMEOUT=30s

# Backpressure and circuit breaker configuration
#BACKPRESSURE_THRESHOLD=1000
#CIRCUIT_BREAKER_THRESHOLD=10
#CIRCUIT_BREAKER_TIMEOUT=60s

# Mimir metrics storage
#MIMIR_URL=http://localhost:9009

# Alerting history webhook authentication (shared secret with backend's
# ALERTING_HISTORY_WEBHOOK_SECRET). Must be at least 32 characters; the
# value is rendered into the Alertmanager YAML pushed to Mimir, so a short
# secret can be cheaply brute-forced from any read of the Mimir bucket.
#ALERTING_HISTORY_WEBHOOK_SECRET=

# Logging configuration
#LOG_LEVEL=info
#LOG_FORMAT=json
#LOG_OUTPUT=stdout
#LOG_FILE_PATH=/var/log/collect.log